                              id="mpChevron">expand_more</span>
                    </button>

                    <!-- Panel -->
                    <div id="mpDropdown"
                         class="hidden absolute right-0 top-[calc(100%+10px)] w-[260px] z-[200]
                                bg-white rounded-[1.4rem] border border-gray-100
                                shadow-[0_24px_64px_rgba(0,0,0,0.13)] overflow-hidden">

                        <div class="px-5 pt-4 pb-2">
                            <p class="text-[10px] font-black uppercase tracking-[0.22em] text-gray-400">
                                Learning Tools
                            </p>
                        </div>

                        <!-- Geometry Calculator -->
                        <a href="GeometryCalc.aspx"
                           class="group flex items-center gap-3 px-4 py-3.5 mx-2 mb-1
                                  rounded-2xl hover:bg-math-blue/5 transition-colors">
                            <div class="size-10 rounded-xl bg-math-blue/10 flex items-center justify-center
                                        flex-shrink-0 group-hover:bg-math-blue transition-colors duration-200">
                                <span class="material-symbols-outlined text-math-blue fill-icon
                                             group-hover:text-white transition-colors">calculate</span>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="font-black text-sm text-math-dark-blue leading-tight
                                          group-hover:text-math-blue transition-colors">
                                    Geometry Calculator
                                </p>
                                <p class="text-[11px] text-gray-400 font-semibold mt-0.5">
                                    Area, circles &amp; Pythagoras
                                </p>
                            </div>
                            <span class="material-symbols-outlined text-gray-300 text-sm
                                         group-hover:text-math-blue transition-colors">chevron_right</span>
                        </a>

                        <!-- Graph Explorer -->
                        <a href="GraphTool.aspx"
                           class="group flex items-center gap-3 px-4 py-3.5 mx-2 mb-2
                                  rounded-2xl hover:bg-math-green/5 transition-colors">
                            <div class="size-10 rounded-xl bg-math-green/10 flex items-center justify-center
                                        flex-shrink-0 group-hover:bg-math-green transition-colors duration-200">
                                <span class="material-symbols-outlined text-math-green fill-icon
                                             group-hover:text-white transition-colors">show_chart</span>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="font-black text-sm text-math-dark-blue leading-tight
                                          group-hover:text-math-blue transition-colors">
                                    Graph Explorer
                                </p>
                                <p class="text-[11px] text-gray-400 font-semibold mt-0.5">
                                    Linear &amp; quadratic graphs
                                </p>
                            </div>
                            <span class="material-symbols-outlined text-gray-300 text-sm
                                         group-hover:text-math-blue transition-colors">chevron_right</span>
                        </a>

                        <div class="border-t border-gray-100 mx-4"></div>
                        <p class="px-5 py-3 text-[10px] font-semibold text-gray-400 italic">
                            More tools coming soon
                        </p>
                    </div>
                </div>
                <!-- End MathPlayground -->
                <!-- Streak + XP + Avatar pill -->
                <div class="flex items-center gap-3 bg-gray-100/80 p-1.5 rounded-full border border-gray-200 shadow-inner">

                    <div class="bg-primary/35 text-math-dark-blue px-3.5 py-1.5 rounded-full flex items-center gap-2 border border-primary/45">
                        <span class="text-lg leading-none" aria-hidden="true">&#128293;</span>
                        <span class="font-black text-sm"><asp:Literal ID="litStreak" runat="server" Text="0" /></span>
                        <span class="text-sm font-semibold text-math-dark-blue/80">Day Streak</span>
                    </div>

                    <div class="flex items-center gap-2 pr-4 pl-1">
                        <div class="size-6 bg-math-blue rounded-full flex items-center justify-center shadow-sm">
                            <span class="material-symbols-outlined text-white text-xs fill-icon">star</span>
                        </div>
                        <span class="font-black text-sm text-math-dark-blue">
                            <asp:Literal ID="litXP" runat="server" Text="0" />
                        </span>
                        <span class="text-sm font-semibold text-gray-500">XP</span>
                    </div>

                                        <a href="StudentProfile.aspx"
                       class="block size-10 rounded-full border-2 border-math-blue overflow-hidden hover:scale-105 transition-transform cursor-pointer"
                       aria-label="Go to profile">
                        <asp:Image ID="imgAvatar" runat="server"
                            CssClass="w-full h-full object-cover bg-blue-100"
                            AlternateText="Avatar" />
                    </a>
                </div>

            </div>
        </div>
    </header>

    <!-- Page Content -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-8 py-12 z-10">
        <asp:ContentPlaceHolder ID="MainContent" runat="server" />
    </main>

    <!-- AI Tutor Widget -->
    <div id="aiTutorRoot" class="fixed bottom-5 right-5 z-[120]">
        <button id="aiTutorFab" type="button"
                class="size-14 rounded-full bg-math-blue hover:bg-math-dark-blue text-white shadow-xl border-2 border-white/70 transition-colors flex items-center justify-center"
