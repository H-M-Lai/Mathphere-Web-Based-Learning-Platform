            <!-- Brand -->
            <a class="flex items-center gap-3" href='<%= IsGuest ? "Default.aspx" : "StudentDashboard.aspx" %>'>

                <img src="Image/white themed MathSphere logo transparent 2.png"
                     class="h-10 lg:h-12 w-auto object-contain" alt="MathSphere Logo" />
                <span class="text-2xl lg:text-3xl font-extrabold tracking-tight uppercase text-math-dark-blue">
                    MATHSPHERE
                </span>
            </a>

            <!-- Nav -->
            <nav id="mainNav" class="relative flex items-center gap-8 ml-12 z-50">
                <a href="StudentDashboard.aspx" class="nav-link" data-match="StudentDashboard">DASHBOARD</a>
                <a href="Missions.aspx"         class="nav-link" data-match="Missions">MISSIONS</a>
                <a href="BrowseModule.aspx"     class="nav-link" data-match="BrowseModule">MODULE</a>
                <a href="Leaderboard.aspx"      class="nav-link" data-match="Leaderboard">LEADERBOARD</a>
                <a href="Forum.aspx"            class="nav-link" data-match="Forum">FORUM</a>
                <span id="navIndicator"
                      class="absolute bottom-[2px] h-1 w-0 bg-math-blue rounded-full transition-all duration-200 ease-out"></span>
            </nav>

            <!-- Right: MathPlayground + Streak/XP/Avatar pill -->
